{
  "name": "@pos/pos-app",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first Electron + React terminal for standalone POS operations.",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"npm:dev\" \"wait-on tcp:5173 && tsc -p tsconfig.main.json && electron .\"",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "package": "npm run build && electron-builder",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@electron/rebuild": "^3.7.2",
    "@pos/shared": "*",
    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^11.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "uuid": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vitest": "^1.5.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.counterflow.pos",
    "productName": "CounterFlow POS",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
