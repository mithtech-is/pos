{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist/main",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@pos/shared": ["../../packages/shared/dist"],
      "@pos/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src/main", "src/preload"]
}
