# Database
DATABASE_URL=postgres://medusa:medusa@localhost:5432/school_uniform_pos
REDIS_URL=redis://localhost:6379

# Secrets — replace with strong values in production
JWT_SECRET=replace_with_secure_secret
COOKIE_SECRET=replace_with_secure_secret

# CORS
ADMIN_CORS=http://localhost:7001,http://localhost:9000
AUTH_CORS=http://localhost:7001,http://localhost:9000
STORE_CORS=http://localhost:7001
POS_CORS=http://localhost:5173,app://./

# POS sync defaults
POS_SYNC_PUSH_BATCH_LIMIT=50
POS_OFFLINE_SESSION_DAYS=7

# Distributor branding (for receipt header)
DISTRIBUTOR_NAME="ABC Uniforms"
DISTRIBUTOR_ADDRESS=""
DISTRIBUTOR_GSTIN=""

# Worker mode (optional separation)
MEDUSA_WORKER_MODE=shared
